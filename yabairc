# https://github.com/asmvik/yabai

# default layout for the yabai tiling window manager: bsp, stack, or float
yabai -m config layout bsp
yabai -m config window_placement second_child
yabai -m config split_ratio 0.55
yabai -m config auto_balance off

# padding
yabai -m config top_padding 4
yabai -m config bottom_padding 4
yabai -m config left_padding 4
yabai -m config right_padding 4
yabai -m config window_gap 4

# mouse settings
yabai -m config mouse_follows_focus on # when change focused window with keyboard mouse follows

# list of apps yabai shouldn't manage - disable
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add title="^Picture-in-Picture$" manage=off
yabai -m rule --add title="^(Downloading)" manage=off
yabai -m rule --add title="^(Move to Trash|Delete|Are you sure)" manage=off

